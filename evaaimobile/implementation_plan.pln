│  │ 🔒    │    │ 🔒    │    │ 🔒    │    │ 🔒    │    │ 🔒    │      │
│  └──────┘    └──────┘    └──────┘    └──────┘    └──────┘      │
│       ↑                                                          │
│     текущий                                                     │
│                                                                  │
│  ┌──────┐    ┌──────┐    ┌──────┐                               │
│  │Слой 5│───▶│Слой 6│───▶│Слой 7│                               │
│  │601-750│   │751-900│   │901-1000│                              │
│  │2 фото │   │1 фото │   │1 видео│                               │
│  │1 видео│   │1 аудио│   │1 фото │                               │
│  │ 🔒    │   │ 🔒    │   │ 🔒    │                               │
│  └──────┘    └──────┘    └──────┘                               │
│                                                                  │
│ ─────────────────────────────────────────────────────────────── │
