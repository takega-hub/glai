│ │ │    параметры. Для грустных — меньше стабильности.      │ │ │
│ │ └─────────────────────────────────────────────────────────┘ │ │
│ └─────────────────────────────────────────────────────────────┘ │
│                                                                  │
│ ┌─────────────────────────────────────────────────────────────┐ │
│ │ ЭМОЦИОНАЛЬНЫЕ ПРЕСЕТЫ                                       │ │
│ │                                                              │ │
│ │ [Нейтральный] [Грустный] [Игривый] [Шепот] [Взволнованный] │ │
│ │                                                              │ │
│ └─────────────────────────────────────────────────────────────┘ │
│                                                                  │
└─────────────────────────────────────────────────────────────────┘
```

